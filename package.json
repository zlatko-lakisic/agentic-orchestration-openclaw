{
  "name": "@zlatko-lakisic/openclaw-agentic-orchestration",
  "version": "1.0.4",
  "description": "OpenClaw plugin that auto-installs/starts agentic-orchestration and routes agent turns through the multi-agent backend",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "patches",
    "assets",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node scripts/strip-test-artifacts.mjs",
    "dev": "tsc --watch",
    "check": "tsc --noEmit",
    "test": "tsc && node --test dist/src/config.test.js dist/src/client.test.js dist/src/hook.test.js dist/src/credentials.test.js dist/src/inject.test.js dist/src/install.test.js",
    "prepublishOnly": "npm run build"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.7.1",
      "pluginSdkVersion": "2026.7.1"
    }
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.24-beta.2"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "agentic-orchestration",
    "crewai",
    "multi-agent"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zlatko-lakisic/agentic-orchestration-openclaw.git"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "dompurify": "^3.4.12",
    "marked": "^18.0.6",
    "tar": "^7.5.20",
    "ws": "^8.21.1"
  }
}
